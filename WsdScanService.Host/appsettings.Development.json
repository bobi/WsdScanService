{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "WsdScanService.Discovery": "Debug"
    },
    "Console": {
      "LogLevel": {
        "WsdScanService": "Debug"
      }
    }
  },
  "WsdScanService": {
    "OutputDir": "./tmp/wsdscan",
    "Sane": {
      "UseSaneBackend": true,
      "Device": "pixma:MF220_{Ip}",
      "ImageConverter": {
        "Path": "magick",
        "Args": [
          "JPG:{InputPath}",
          "-gamma",
          "2.2",
          "-quality",
          "92",
          "-sampling-factor",
          "4:2:0",
          "-interlace",
          "Plane",
          "-strip",
          "JPG:{OutputPath}"
        ]
      }
    },
    "ScanProfiles": [
      {
        "DisplayName": "Scan to LOCAL (300dpi)",
        "Resolution": 300
      },
      {
        "DisplayName": "Scan to LOCAL (600dpi)",
        "Resolution": 600
      }
    ]
  }
}
